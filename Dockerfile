FROM node:20-bookworm-slim

WORKDIR /app

# Git commit passed as build arg (generated by docker-compose or build script)
ARG GIT_COMMIT=unknown

RUN apt-get update \
  && apt-get install -y --no-install-recommends \
    python3 \
    python3-pip \
    python3-venv \
    ca-certificates \
    docker.io \
  && rm -rf /var/lib/apt/lists/*

RUN python3 -m venv /opt/ai-venv
ENV PATH="/opt/ai-venv/bin:$PATH"

RUN pip install --no-cache-dir --upgrade pip \
  && pip install --no-cache-dir scikit-learn numpy joblib

COPY package.json package-lock.json* ./

RUN npm install

COPY . .

# Write VERSION file from build arg
RUN if [ -s VERSION ] && [ "$(cat VERSION)" != "unknown" ]; then :; else echo "${GIT_COMMIT}" > VERSION; fi

RUN npm run build

EXPOSE 5000

ENV NODE_ENV=production
ENV PORT=5000

CMD ["sh", "-c", "npx tsx script/migrate.ts && npm start"]
